---
import { tagUrl } from '../lib/posts';

interface Props {
  tags: Array<{ name: string; count: number }>;
}

const { tags } = Astro.props;
---

<div class="tag-cloud">
  {
    tags.map((tag) => (
      <a href={tagUrl(tag.name)}>
        <span>{tag.name}</span>
        <small>{tag.count}</small>
      </a>
    ))
  }
</div>
